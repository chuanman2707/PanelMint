# Core app
# Local Postgres example. On Vercel + Neon use the pooled transaction URL
# for DATABASE_URL and keep DIRECT_URL as the direct 5432 connection for migrations.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/weoweo?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/weoweo?schema=public
ENCRYPTION_SECRET=replace-with-a-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000

# Clerk auth target runtime
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Inngest target runtime
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Platform-managed provider keys
WAVESPEED_API_KEY=
OPENROUTER_API_KEY=

# Cloudflare R2 (optional, required only when storage is enabled)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=weoweo
R2_PUBLIC_URL=
