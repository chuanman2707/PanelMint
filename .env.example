# Neon Postgres
# Copy the pooled connection string from Neon -> Connect for DATABASE_URL.
# Copy the direct connection string from the same modal for DIRECT_URL.
# Prisma CLI prefers DIRECT_URL for migrations when it is set.
#
# Neon's default database name is usually `neondb` unless you explicitly created another one.
DATABASE_URL=postgresql://USER:PASSWORD@ep-your-project-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-your-project.REGION.aws.neon.tech/neondb?sslmode=require
# Local Docker fallback:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/panelmint?schema=public
# DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/panelmint?schema=public

# App security
ALLOWED_ORIGINS=http://localhost:3000

# Inngest background jobs
# In production, set both values from your Inngest environment.
# For local dev with the Inngest Dev Server, leave them blank and uncomment INNGEST_DEV.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# INNGEST_DEV=1

# WaveSpeed BYOK provider key
# Required for local generation. Get a key from https://wavespeed.ai/accesskey.
WAVESPEED_API_KEY=

# Optional model overrides / tuning
IMAGE_MODEL=wavespeed-ai/flux-kontext-pro/multi
LLM_MODEL=
IMAGE_RATE_LIMIT=10
IMAGE_RATE_LIMIT_TIMEOUT_MS=120000

# Cloudflare R2 (optional, required only when storage is enabled)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=panelmint
R2_PUBLIC_URL=
